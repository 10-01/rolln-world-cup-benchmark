API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# === Live results snapshot storage (highly recommended for production) ===
# Use REDIS_URL with a redis:// connection string (works in dev + on Vercel).
# REDIS_URL=redis://default:YOUR_TOKEN@your-redis-host:port
#
# The resolver in src/lib/resolve-results.ts will automatically use it for:
#   - Writing snapshots on the Vercel cron (/api/live-results?cron=1)
#   - Serving a durable "last resolved" feed so most requests avoid hitting the football API
#
# You can also use the old Vercel KV REST vars (KV_REST_API_URL + KV_REST_API_TOKEN) as fallback.
# For Vercel: add the Redis URL as an Environment Variable (or connect via Marketplace → Redis).

# Optional legacy KV REST (only needed if not using REDIS_URL)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
